# CTRG Grant System - Local Development Environment
SECRET_KEY=local-dev-secret-key-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,192.168.0.104

# SQLite for local development (no PostgreSQL needed)
DATABASE_ENGINE=django.db.backends.sqlite3
DATABASE_NAME=db.sqlite3

# Email (Gmail SMTP)
# IMPORTANT: Never commit real credentials to version control.
# Revoke the old app password immediately and generate a new one.
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password-here
DEFAULT_FROM_EMAIL=CTRG Grant System <your-email@gmail.com>

# Frontend URL (for invitation links, emails, etc.)
FRONTEND_URL=http://localhost:5173

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173,http://192.168.0.104:5173
CORS_ALLOW_CREDENTIALS=True

# Security (relaxed for local dev)
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False

# File Upload
FILE_UPLOAD_MAX_MEMORY_SIZE=52428800
DATA_UPLOAD_MAX_MEMORY_SIZE=52428800

# Encryption (disabled for local dev)
FILE_ENCRYPTION_KEY=

# Application
TIME_ZONE=UTC
LANGUAGE_CODE=en-us
